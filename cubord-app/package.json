{
  "name": "cubord-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@tanstack/.*|@supabase/.*|zustand|msw|until-async)"
    ],
    "moduleNameMapper": {
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@stores/(.*)$": "<rootDir>/src/stores/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@types/(.*)$": "<rootDir>/src/types/$1",
      "^@contexts/(.*)$": "<rootDir>/src/contexts/$1",
      "^@boot/(.*)$": "<rootDir>/src/boot/$1",
      "^@api/(.*)$": "<rootDir>/src/api/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@styles/(.*)$": "<rootDir>/src/styles/$1",
      "^@lib/(.*)$": "<rootDir>/src/lib/$1",
      "^@screens/(.*)$": "<rootDir>/src/screens/$1",
      "^@test/(.*)$": "<rootDir>/src/test/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1"
    }
  },
  "dependencies": {
    "@expo-google-fonts/nunito-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.90.20",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "expo": "~55.0.13",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.15",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.24",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.12",
    "expo-modules-core": "^55.0.22",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "jest-expo": "~55.0.15",
    "msw": "^2.12.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.7.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^16.6.1",
    "jest": "^29.2.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
