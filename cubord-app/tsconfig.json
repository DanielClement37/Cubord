{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@components/*": ["src/components/*"],
      "@services/*":   ["src/services/*"],
      "@stores/*":     ["src/stores/*"],
      "@hooks/*":      ["src/hooks/*"],
      "@types/*":      ["src/types/*"],
      "@contexts/*":   ["src/contexts/*"],
      "@boot/*":       ["src/boot/*"],
      "@api/*":        ["src/api/*"],
      "@utils/*":      ["src/utils/*"],
      "@styles/*":     ["src/styles/*"],
      "@lib/*":        ["src/lib/*"],
      "@screens/*":    ["src/screens/*"],
      "@test/*":       ["src/test/*"],
      "@assets/*":     ["assets/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
